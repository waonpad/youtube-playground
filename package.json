    "googleapis": "^167.0.0",
    "ytmusic-api": "^5.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.4",
    "@types/server-destroy": "^1.0.4",
    "lefthook": "^2.0.9",
    "open": "^11.0.0",
    "server-destroy": "^1.0.1",
    "typescript": "^5.9.3"
  }
}
